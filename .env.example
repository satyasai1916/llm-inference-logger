# Database — SQLite for dev, Postgres for prod
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:password@localhost:5432/llm_logger"

# LLM Provider API Keys
GEMINI_API_KEY=your-gemini-api-key
GROK_API_KEY=your-grok-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Claude mode: "sdk" (default) or "bedrock"
CLAUDE_MODE=sdk

# For Bedrock proxy mode only
# BEDROCK_BASE_URL=
# BEDROCK_BEARER_TOKEN=

# App base URL (used server-side for internal ingest dispatch)
BASE_URL=http://localhost:3000
